# Copied to ~/.copilot/tools/.env on install (--all or --tool=jira,confluence,gitlab) if that
# file doesn't already exist yet — an existing .env is never overwritten. Fill in real values
# there, not here: this file stays committed with placeholders only.
#
# Atlassian Cloud auth: email + API token (Basic auth), not a bearer PAT — see TOOLS-DESIGN.md
# §4. Generate an API token at https://id.atlassian.com/manage-profile/security/api-tokens.
# Email/token are almost always identical for Jira and Confluence Cloud (same Atlassian
# account) — kept as separate variables per service in case they ever diverge.

JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# GitLab auth is a personal access token sent as the PRIVATE-TOKEN header — a different scheme
# entirely from the Atlassian Basic-auth pair above, no email involved (TOOLS-DESIGN.md §4).
# Works against gitlab.com (the default below) or any self-hosted instance — just change the
# base URL, the script never hardcodes gitlab.com. Minimum required token scope: read_api.
# Generate one at <GITLAB_BASE_URL>/-/user_settings/personal_access_tokens.
GITLAB_BASE_URL=https://gitlab.com
GITLAB_API_TOKEN=
